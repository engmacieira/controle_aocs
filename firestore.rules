rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper functions for data types
    function isString(val) { return val is string; }
    function isNumber(val) { return val is number; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /base/{baseId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(baseId);
      allow delete: if isSignedIn() && isValidId(baseId);
    }
    
    match /pedidos/{pedidoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(pedidoId);
      allow delete: if isSignedIn() && isValidId(pedidoId);
    }

    match /aocs/{aocsId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(aocsId);
      allow delete: if isSignedIn() && isValidId(aocsId);
    }

    match /ci/{ciId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(ciId);
      allow delete: if isSignedIn() && isValidId(ciId);
    }
    
    match /extrato/{extratoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(extratoId);
      allow delete: if isSignedIn() && isValidId(extratoId);
    }

    match /contas/{contasId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(contasId);
      allow delete: if isSignedIn() && isValidId(contasId);
    }

    match /dados/{dadosId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(dadosId);
      allow delete: if isSignedIn() && isValidId(dadosId);
    }
    match /registro_atividades/{atividadeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(atividadeId);
      allow delete: if isSignedIn() && isValidId(atividadeId);
    }
    match /lancamentos_futuros/{lancamentoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(lancamentoId);
      allow delete: if isSignedIn() && isValidId(lancamentoId);
    }
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // audit logs should typically be append-only, but let's just use create for now
      // or allow create, update, delete for simplicity and matching the others
      allow update, delete: if isSignedIn();
    }
  }
}
